<!DOCTYPE Menu PUBLIC '-//freedesktop//DTD Menu 1.0//EN' 'http://www.freedesktop.org/standards/menu-spec/menu-1.0.dtd'>
<Menu>
 <Layout>
  <Merge type="menus"/>
  <Menuname>Office</Menuname>
  <Menuname>Graphics</Menuname>
  <Menuname>Games</Menuname>
  <Menuname>Internet</Menuname>
  <Menuname>Multimedia</Menuname>
  <Menuname>Utilities</Menuname>
  <Menuname>System</Menuname>
  <Menuname>Applications</Menuname>
 </Layout>
 <Menu>
  <Name>Office</Name>
  <Exclude>
   <Filename>libreoffice-draw.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>libreoffice-startcenter.desktop</Filename>
   <Filename>libreoffice-base.desktop</Filename>
   <Filename>libreoffice-calc.desktop</Filename>
   <Filename>libreoffice-impress.desktop</Filename>
   <Filename>libreoffice-math.desktop</Filename>
   <Filename>libreoffice-writer.desktop</Filename>
   <Filename>org.kde.okular.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Graphics</Name>
  <Exclude>
   <Filename>org.kde.okular.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>gimp.desktop</Filename>
   <Filename>gmic_qt.desktop</Filename>
   <Filename>org.kde.gwenview.desktop</Filename>
   <Filename>org.kde.krita.desktop</Filename>
   <Filename>libreoffice-draw.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Multimedia</Name>
  <Exclude>
   <Filename>qv4l2.desktop</Filename>
   <Filename>qvidcap.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>aimp.utils.tageditor.desktop</Filename>
   <Filename>aimp.desktop</Filename>
   <Filename>audacity.desktop</Filename>
   <Filename>aimp.utils.converter.desktop</Filename>
   <Filename>org.kde.kdenlive.desktop</Filename>
   <Filename>org.mixxx.Mixxx.desktop</Filename>
   <Filename>vlc.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Utilities</Name>
  <Exclude>
   <Filename>org.kde.kwrite.desktop</Filename>
   <Filename>vim.desktop</Filename>
   <Filename>com.shellyorg.shelly.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>org.kde.ark.desktop</Filename>
   <Filename>org.bleachbit.BleachBit.desktop</Filename>
   <Filename>org.kde.kate.desktop</Filename>
   <Merge type="menus"/>
   <Menuname>XUtilities</Menuname>
   <Filename>org.kde.spectacle.desktop</Filename>
   <Filename>ventoy.desktop</Filename>
   <Filename>winetricks.desktop</Filename>
   <Filename>org.kde.plasma.emojier.desktop</Filename>
   <Separator/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>System</Name>
  <Exclude>
   <Filename>org.bleachbit.BleachBit.desktop</Filename>
   <Filename>org.kde.kinfocenter.desktop</Filename>
   <Filename>lstopo.desktop</Filename>
   <Filename>avahi-discover.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>Konserwacja systemu.desktop</Filename>
   <Filename>btop.desktop</Filename>
   <Filename>org.kde.dolphin.desktop</Filename>
   <Filename>ca.desrt.dconf-editor.desktop</Filename>
   <Filename>org.kde.kmenuedit.desktop</Filename>
   <Filename>org.kde.konsole.desktop</Filename>
   <Filename>lsfg-vk-ui.desktop</Filename>
   <Filename>virt-manager.desktop</Filename>
   <Merge type="menus"/>
   <Menuname>Terminal</Menuname>
   <Menuname>ScreenSavers</Menuname>
   <Filename>com.shellyorg.shelly.desktop</Filename>
   <Filename>system-config-printer.desktop</Filename>
   <Filename>systemsettings.desktop</Filename>
   <Filename>nm-connection-editor.desktop</Filename>
   <Filename>cups.desktop</Filename>
   <Filename>org.kde.partitionmanager.desktop</Filename>
   <Separator/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Education</Name>
  <Deleted/>
 </Menu>
 <Menu>
  <Name>Development</Name>
  <Deleted/>
 </Menu>
 <Menu>
  <Name>Science</Name>
  <Deleted/>
 </Menu>
 <Menu>
  <Name>Help</Name>
  <Deleted/>
 </Menu>
 <Menu>
  <Name>.hidden</Name>
  <Include>
   <Filename>org.kde.okular.desktop</Filename>
   <Filename>libreoffice-draw.desktop</Filename>
   <Filename>qv4l2.desktop</Filename>
   <Filename>qvidcap.desktop</Filename>
   <Filename>org.kde.kwrite.desktop</Filename>
   <Filename>vim.desktop</Filename>
   <Filename>org.bleachbit.BleachBit.desktop</Filename>
   <Filename>org.kde.kinfocenter.desktop</Filename>
   <Filename>lstopo.desktop</Filename>
   <Filename>com.shellyorg.shelly.desktop</Filename>
   <Filename>avahi-discover.desktop</Filename>
  </Include>
 </Menu>
 <Menu>
  <Name>Games</Name>
  <Layout>
   <Merge type="files"/>
   <Filename>faugus-launcher.desktop</Filename>
   <Filename>io.github.benjamimgois.goverlay.desktop</Filename>
   <Merge type="menus"/>
   <Menuname>Kidsgames</Menuname>
   <Menuname>Card</Menuname>
   <Menuname>Logic</Menuname>
   <Menuname>Board</Menuname>
   <Menuname>TacticStrategy</Menuname>
   <Menuname>Arcade</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Internet</Name>
  <Layout>
   <Merge type="files"/>
   <Filename>brave-browser.desktop</Filename>
   <Filename>discord.desktop</Filename>
   <Filename>gmail.desktop</Filename>
   <Filename>google-chrome.desktop</Filename>
   <Merge type="menus"/>
   <Menuname>Terminal</Menuname>
   <Filename>bssh.desktop</Filename>
   <Filename>bvnc.desktop</Filename>
   <Filename>org.qbittorrent.qBittorrent.desktop</Filename>
   <Filename>org.telegram.desktop.desktop</Filename>
   <Separator/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
</Menu>
